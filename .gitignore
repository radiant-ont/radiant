# === Large / regenerable intermediates (excluded; regenerate from SRA) ===
# Raw and trimmed ONT reads (download from SRA: SRR37392029/30/31).
*.fastq
*.fastq.gz
*.fq
*.fq.gz
# Per-read annotation tables (~27 MB each; regenerated by the pipeline).
data/runs/paper_ont/*/annotate_in/
data/runs/paper_ont/*/annotate_out/
data/runs/paper_ont/*/consensus_annotate_in/
data/runs/paper_ont/*/consensus/
data/runs/germline_mock/

# === Proprietary, never publish; redistribution prohibited (see LICENSE) ===
# PacBio references
data/NGS/
*_DB_verified*.txt
GEN3*
VHH_*_DB*
# Raw reference FASTA is not tracked (only the annotated reference CSV is).
data/Sanger/*_Sanger.fasta
data/Sanger/*_uniques.fasta
data/Sanger/down.sanger.*.csv

# === Kept for reproduction (explicitly un-ignored) ===
!data/runs/paper_ont/*/consensus_annotate_out/
!data/runs/paper_ont/*_picks.csv
!data/runs/paper_ont/*_leads.csv
!data/Sanger/*_annotated_reference.csv
!data/generated/

# === Build / cruft ===
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/
.DS_Store
packaging/radiant_annotator/.build/
packaging/radiant_annotator/dist/
packaging/radiant_annotator/radiant_annotator/bin/annotator

# Synthetic mock reads are tracked (overrides *.fastq)
!data/generated/germline_mock.fastq

# Internal annotator build tooling (references internal source; never publish)
packaging/radiant_annotator/annotator_cli.py
packaging/radiant_annotator/build_annotator.sh
packaging/radiant_annotator/BUILD_INTERNAL.md
packaging/radiant_annotator/build/

